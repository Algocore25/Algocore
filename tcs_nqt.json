[
  {
    "id": "sql_comprehensive_course",
    "title": "Comprehensive SQL & Database Mastery",
    "description": "A complete SQL course covering SELECT basics, filtering, joins, aggregations, subqueries, window functions, DDL, DML, indexes, and advanced topics.",
    "level": "Beginner to Advanced",
    "accessType": "open",
    "allowedLanguages": [
      "SQL"
    ],
    "sections": {
      "Section 1: Basic SELECT Queries": {
        "description": "Foundational SELECT statements to retrieve data from single tables.",
        "questions": [
          {
            "questionname": "Select All Rows",
            "type": "SQL",
            "difficulty": "Easy",
            "question": "Write a SQL query to retrieve all columns and all rows from the `products` table.",
            "schema": "CREATE TABLE products (id INT PRIMARY KEY, name VARCHAR(100), category VARCHAR(50), price DECIMAL(10,2), stock INT);\nINSERT INTO products VALUES (1,'Laptop','Electronics',999.99,50);\nINSERT INTO products VALUES (2,'Chair','Furniture',149.99,200);\nINSERT INTO products VALUES (3,'Pen','Stationery',1.99,1000);\nINSERT INTO products VALUES (4,'Desk','Furniture',299.99,80);\nINSERT INTO products VALUES (5,'Monitor','Electronics',399.99,120);",
            "solution": "SELECT * FROM products;",
            "testcases": [
              {
                "input": "",
                "expectedOutput": "1|Laptop|Electronics|999.99|50\n2|Chair|Furniture|149.99|200\n3|Pen|Stationery|1.99|1000\n4|Desk|Furniture|299.99|80\n5|Monitor|Electronics|399.99|120"
              }
            ],
            "id": "sec_01_q01"
          },
          {
            "questionname": "Select Specific Columns",
            "type": "SQL",
            "difficulty": "Easy",
            "question": "Write a SQL query to retrieve only the `name` and `price` columns from the `products` table.",
            "schema": "CREATE TABLE products (id INT PRIMARY KEY, name VARCHAR(100), category VARCHAR(50), price DECIMAL(10,2), stock INT);\nINSERT INTO products VALUES (1,'Laptop','Electronics',999.99,50);\nINSERT INTO products VALUES (2,'Chair','Furniture',149.99,200);\nINSERT INTO products VALUES (3,'Pen','Stationery',1.99,1000);\nINSERT INTO products VALUES (4,'Desk','Furniture',299.99,80);\nINSERT INTO products VALUES (5,'Monitor','Electronics',399.99,120);",
            "solution": "SELECT name, price FROM products;",
            "testcases": [
              {
                "input": "",
                "expectedOutput": "Laptop|999.99\nChair|149.99\nPen|1.99\nDesk|299.99\nMonitor|399.99"
              }
            ],
            "id": "sec_01_q02"
          },
