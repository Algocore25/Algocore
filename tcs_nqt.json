          {
            "questionname": "Recursive CTE - Hierarchy",
            "type": "SQL",
            "difficulty": "Hard",
            "question": "Use a recursive CTE to find all subordinates (direct and indirect) of employee with id=1. Return `id` and `name`.",
            "schema": "CREATE TABLE employees (id INT PRIMARY KEY, name VARCHAR(100), manager_id INT);\nINSERT INTO employees VALUES (1,'Alice',NULL),(2,'Bob',1),(3,'Carol',1),(4,'Dave',2),(5,'Eve',3);",
            "solution": "WITH RECURSIVE subordinates AS (SELECT id, name FROM employees WHERE manager_id = 1 UNION ALL SELECT e.id, e.name FROM employees e JOIN subordinates s ON e.manager_id = s.id) SELECT id, name FROM subordinates;",
            "testcases": [
