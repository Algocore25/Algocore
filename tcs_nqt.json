          {
            "questionname": "Running Rank with CTE",
            "type": "SQL",
            "difficulty": "Hard",
            "question": "Use a CTE with ROW_NUMBER to get the top 2 highest-paid employees per department. Return `name`, `department`, `salary`.",
            "schema": "CREATE TABLE employees (id INT PRIMARY KEY, name VARCHAR(100), department VARCHAR(50), salary DECIMAL(10,2));\nINSERT INTO employees VALUES (1,'Alice','Engineering',95000),(2,'Bob','Engineering',110000),(3,'Carol','Engineering',88000),(4,'Dave','HR',75000),(5,'Eve','HR',80000),(6,'Frank','HR',68000);",
            "solution": "WITH ranked AS (SELECT name, department, salary, ROW_NUMBER() OVER (PARTITION BY department ORDER BY salary DESC) AS rn FROM employees) SELECT name, department, salary FROM ranked WHERE rn <= 2;",
            "testcases": [
              {
                "input": "",
                "expectedOutput": "Bob|Engineering|110000.00\nAlice|Engineering|95000.00\nEve|HR|80000.00\nDave|HR|75000.00"
