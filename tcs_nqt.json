        "questions": [
          {
            "questionname": "Basic CTE",
            "type": "SQL",
            "difficulty": "Medium",
            "question": "Use a CTE named `high_earners` to find employees with salary > 90000. Return `name` and `salary` from the CTE.",
            "schema": "CREATE TABLE employees (id INT PRIMARY KEY, name VARCHAR(100), department VARCHAR(50), salary DECIMAL(10,2));\nINSERT INTO employees VALUES (1,'Alice','Engineering',95000),(2,'Bob','Marketing',72000),(3,'Carol','Engineering',105000),(4,'Dave','HR',68000);",
            "solution": "WITH high_earners AS (SELECT name, salary FROM employees WHERE salary > 90000) SELECT name, salary FROM high_earners;",
            "testcases": [
