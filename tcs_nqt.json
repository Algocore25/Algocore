            "schema": "CREATE TABLE sales (id INT PRIMARY KEY, region VARCHAR(50), amount DECIMAL(10,2));\nINSERT INTO sales VALUES (1,'North',500),(2,'South',300),(3,'North',200),(4,'East',400),(5,'South',100);",
            "solution": "SELECT SUM(CASE WHEN region='North' THEN amount ELSE 0 END) AS north_total, SUM(CASE WHEN region='South' THEN amount ELSE 0 END) AS south_total, SUM(CASE WHEN region='East' THEN amount ELSE 0 END) AS east_total FROM sales;",
