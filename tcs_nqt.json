          {
            "questionname": "Multiple CTEs",
            "type": "SQL",
            "difficulty": "Hard",
            "question": "Use two CTEs: `dept_avg` to compute average salary per department, and `above_avg` to find employees earning above their department average. Return `name`, `department`, `salary`.",
            "schema": "CREATE TABLE employees (id INT PRIMARY KEY, name VARCHAR(100), department VARCHAR(50), salary DECIMAL(10,2));\nINSERT INTO employees VALUES (1,'Alice','Engineering',95000),(2,'Bob','Engineering',110000),(3,'Carol','HR',68000),(4,'Dave','HR',80000),(5,'Eve','Marketing',72000);",
            "solution": "WITH dept_avg AS (SELECT department, AVG(salary) AS avg_salary FROM employees GROUP BY department), above_avg AS (SELECT e.name, e.department, e.salary FROM employees e JOIN dept_avg d ON e.department = d.department WHERE e.salary > d.avg_salary) SELECT name, department, salary FROM above_avg;",
            "testcases": [
              {
                "input": "",
                "expectedOutput": "Bob|Engineering|110000.00\nDave|HR|80000.00"
              }
            ],
            "id": "sec_10_q02"
          },
          {
            "questionname": "CASE Expression",
            "type": "SQL",
            "difficulty": "Medium",
            "question": "Retrieve `name`, `salary`, and a `salary_band` column: 'High' if salary > 90000, 'Medium' if between 70000 and 90000, otherwise 'Low'.",
            "schema": "CREATE TABLE employees (id INT PRIMARY KEY, name VARCHAR(100), salary DECIMAL(10,2));\nINSERT INTO employees VALUES (1,'Alice',95000),(2,'Bob',72000),(3,'Carol',105000),(4,'Dave',68000),(5,'Eve',80000);",
            "solution": "SELECT name, salary, CASE WHEN salary > 90000 THEN 'High' WHEN salary BETWEEN 70000 AND 90000 THEN 'Medium' ELSE 'Low' END AS salary_band FROM employees;",
            "testcases": [
